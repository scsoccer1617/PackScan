# Required for VLM scanning (Holo / Gemini integration).
# Get a key from https://aistudio.google.com/apikey
# In Replit, add this as a Secret instead of editing .env directly.
GEMINI_API_KEY=

# PR #162: Gate the legacy CardDB lookup pipeline. When unset / "false",
# Gemini VLM is the sole authority for brand/year/player/parallel and the
# CardDB surname-probe + lookup branch in dualSideOCR is skipped entirely.
# Flip to "true" to re-enable the legacy pipeline (e.g. for A/B comparison).
CARDDB_LOOKUP_ENABLED=false

# Existing PackScan environment variables (document yours here as needed)
# DATABASE_URL=
# GOOGLE_APPLICATION_CREDENTIALS=
