# Required for VLM scanning (Holo / Gemini integration).
# Get a key from https://aistudio.google.com/apikey
# In Replit, add this as a Secret instead of editing .env directly.
GEMINI_API_KEY=

# PR #162: Gate the legacy CardDB lookup pipeline. When unset / "false",
# Gemini VLM is the sole authority for brand/year/player/parallel and the
# CardDB surname-probe + lookup branch in dualSideOCR is skipped entirely.
# Flip to "true" to re-enable the legacy pipeline (e.g. for A/B comparison).
CARDDB_LOOKUP_ENABLED=false

# VLM model selection. Defaults below are the production values.
# The primary is tried first; if it errors with a model-availability error
# (404 / "model not found" / preview deprecation), the request is retried
# once on the fallback. Transient 429/quota errors stay on the per-model
# retry loop and don't trigger a swap. Override either side to pin a
# specific model for tests or rollback (e.g. set VLM_MODEL=gemini-2.5-flash
# to revert the production model entirely).
VLM_MODEL=gemini-3-flash-preview
VLM_FALLBACK_MODEL=gemini-2.5-flash

# Existing PackScan environment variables (document yours here as needed)
# DATABASE_URL=
# GOOGLE_APPLICATION_CREDENTIALS=
